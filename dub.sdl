name "llm_fun"
description "LLM agent harness"
authors "Joakim Brännström"
copyright "Copyright © 2026, Joakim Brännström"
license "MPL-2.0"

dependency "colorlog" version="~>0.0.10"
dependency "proc" version="~>1.1.5"
dependency "mylib" version="~>0.0.49"
dependency "argparse" version="~>2.0.2"
dependency "requests" version="~>2.2.0"

targetPath "build"
targetType "executable"

configuration "default" {
    preBuildCommands "make -C $PACKAGE_DIR -f linenoise.mak" platform="posix"
    dflags "-P-I./vendor/linenoise"

    sourceFiles "./build/linenoise.o"
    mainSourceFile "source/app.d"
    excludeSourceFiles "source/utility_app.d"
}

configuration "test_app" {
    targetName "llm_fun_test"

    preBuildCommands "make -C $PACKAGE_DIR -f linenoise.mak" platform="posix"
    dflags "-P-I./vendor/linenoise"

    sourceFiles "./build/linenoise.o"
    mainSourceFile "source/utility_app.d"
    excludeSourceFiles "source/app.d"
}
